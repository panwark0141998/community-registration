generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String
  role      String   @default("family_rep")
  phone     String
  image     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  families  Family[]
  posts     Post[]
  likes     Like[]

  @@map("User")
}

model Family {
  id                    String    @id @default(cuid())
  familyId              String    @unique
  representativeId      String
  headOfFamily          String
  headGender            String?
  headDob               DateTime?
  fatherName            String?
  motherName            String?
  fatherState           String?
  fatherDistrict        String?
  fatherSubDistrict     String?
  fatherVillage         String?
  fatherPincode         String?
  fatherPincodeVillages String?
  caste                 String
  street                String?
  village               String?
  subDistrict           String?
  district              String    @default("")
  state                 String
  pincode               String
  pincodeVillages       String?
  contactNumber         String
  familyPhoto           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  representative        User      @relation(fields: [representativeId], references: [id])
  members               Member[]
}

model Member {
  id                    String   @id @default(cuid())
  familyId              String
  fullName              String
  gender                String
  dob                   DateTime
  relationshipToHead    String
  fatherName            String?
  motherName            String?
  fatherState           String?
  fatherDistrict        String?
  fatherSubDistrict     String?
  fatherVillage         String?
  fatherPincode         String?
  fatherPincodeVillages String?
  maritalStatus         String   @default("Single")
  spouseName            String?
  education             String?
  occupation            String?
  bloodGroup            String?
  isAlive               Boolean  @default(true)
  memberPhoto           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  family                Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  shares    Int      @default(0)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  likes     Like[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Location {
  id          String   @id @default(cuid())
  state       String
  district    String
  subDistrict String
  village     String
  vlistCode   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([state, district, subDistrict, village])
}
